// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  ADMIN
  EMPLOYEE
}

enum LeaveType {
  SICK
  TRANSPORT_WEATHER
  PERSONAL
  GENERAL
}

enum HalfDaySlot {
  FIRST_HALF
  SECOND_HALF
}

enum LeaveStatus {
  PENDING
  APPROVED
  REJECTED
  CANCELLED
  ABSENT
}

enum WfhStatus {
  PENDING
  APPROVED
  REJECTED
  CANCELLED
}

enum SaturdayRule {
  NONE
  ALL
  FIRST
  SECOND
  THIRD
  FOURTH
  FIRST_THIRD
  SECOND_FOURTH
}

enum ProbationRule {
  NONE
  NO_LEAVES
  UNPAID_ALLOWED
}

model User {
  id           String    @id @default(cuid())
  email        String    @unique
  password     String
  role         Role      @default(EMPLOYEE)
  isFirstLogin Boolean   @default(true)
  tokenVersion Int       @default(0)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  employee      Employee?
  notifications Notification[]
}

model Employee {
  id                 String             @id @default(cuid())
  userId             String             @unique
  user               User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  employeeId         String             @unique
  fullName           String
  personalEmail      String?
  mobile             String?
  department         String?
  designation        String?
  dateOfJoining      DateTime?
  birthday           DateTime?
  probationMonths    Int                @default(6)
  reportingManagerId String?
  reportingManager   Employee?          @relation("ManagerToEmployee", fields: [reportingManagerId], references: [id])
  directReports      Employee[]         @relation("ManagerToEmployee")
  isActive           Boolean            @default(true)
  leavePolicyId      String?
  leavePolicy        LeavePolicy?       @relation(fields: [leavePolicyId], references: [id])
  wfhPolicyId        String?
  wfhPolicy          WfhPolicy?         @relation(fields: [wfhPolicyId], references: [id])
  workingSchedule    WorkingSchedule?
  policyExceptions   PolicyException[]
  wfhPolicyExceptions WfhPolicyException[]
  leaveApplications  LeaveApplication[]
  monthlyReports     MonthlyReport[]
  wfhApplications    WfhApplication[]
  leaveBalances      LeaveBalance[]
  absentRecords      AbsentRecord[]
  announcementDismissals  AnnouncementDismissal[]
  attendanceCorrections   AttendanceCorrection[]
  checkInRecords          CheckInRecord[]
  swapDays                SwapDay[]
  lateRecords             LateRecord[]
  canViewTeamCalendar  Boolean            @default(false)

  // Notice period
  isOnNoticePeriod   Boolean    @default(false)
  noticePeriodStart  DateTime?
  noticePeriodEnd    DateTime?
  noticePeriodType   String?    // RESIGNED | TERMINATED | MUTUAL
  earlyReleaseDate   DateTime?
  allowLeaveOverride Boolean    @default(false)

  // Onboarding
  onboardingCompleted Boolean  @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model LeavePolicy {
  id               String            @id @default(cuid())
  name             String
  leaveType        LeaveType         @default(GENERAL)
  daysAllowed      Float
  approvalRequired Boolean           @default(true)
  noticeRequired   Boolean           @default(false)
  minNoticeDays    Int               @default(0)
  halfDayAllowed   Boolean           @default(true)
  carryForward     Boolean           @default(false)
  probationRule    ProbationRule     @default(NONE)
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
  employees        Employee[]
  exceptions       PolicyException[]
  rules            PolicyRule[]
}

model PolicyException {
  id                 String      @id @default(cuid())
  policyId           String
  policy             LeavePolicy @relation(fields: [policyId], references: [id], onDelete: Cascade)
  employeeId         String
  employee           Employee    @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  overrideDays       Float
  blackoutFrom       DateTime
  blackoutTo         DateTime
  allowedLeaveTypes  LeaveType[]
  createdAt          DateTime    @default(now())
  updatedAt          DateTime    @updatedAt
}

model PolicyRule {
  id                   String      @id @default(cuid())
  policyId             String
  policy               LeavePolicy @relation(fields: [policyId], references: [id], onDelete: Cascade)
  operator             String      @default("GTE")  // GTE>=  GT>  LTE<=  LT<  EQ=
  minDays              Float
  approvalRequired     Boolean     @default(true)
  noticeRequired       Boolean     @default(false)
  minNoticeDays        Int         @default(0)
  exception            String?
  applicableLeaveTypes LeaveType[]
  createdAt            DateTime    @default(now())
  updatedAt            DateTime    @updatedAt
}

model WfhPolicy {
  id               String               @id @default(cuid())
  name             String
  daysAllowed      Int
  approvalRequired Boolean              @default(true)
  noticeRequired   Boolean              @default(false)
  minNoticeDays    Int                  @default(0)
  halfDayAllowed   Boolean              @default(true)
  probationRule    ProbationRule        @default(NONE)
  createdAt        DateTime             @default(now())
  updatedAt        DateTime             @updatedAt
  employees        Employee[]
  exceptions       WfhPolicyException[]
  rules            WfhPolicyRule[]
}

model WfhPolicyException {
  id           String      @id @default(cuid())
  policyId     String
  policy       WfhPolicy   @relation(fields: [policyId], references: [id], onDelete: Cascade)
  employeeId   String
  employee     Employee    @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  overrideDays Float
  blackoutFrom DateTime
  blackoutTo   DateTime
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt
}

model WfhPolicyRule {
  id               String      @id @default(cuid())
  policyId         String
  policy       WfhPolicy   @relation(fields: [policyId], references: [id], onDelete: Cascade)
  operator         String      @default("GTE")  // GTE>=  GT>  LTE<=  LT<  EQ=
  minDays          Float
  approvalRequired Boolean     @default(true)
  noticeRequired   Boolean     @default(false)
  minNoticeDays    Int         @default(0)
  exception        String?
  createdAt        DateTime    @default(now())
  updatedAt        DateTime    @updatedAt
}

model WorkingSchedule {
  id            String       @id @default(cuid())
  employeeId    String       @unique
  employee      Employee     @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  workingDays   String[]
  saturdayRule  SaturdayRule @default(NONE)
  monthlyTarget Int?
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt
}

model PublicHoliday {
  id        String   @id @default(cuid())
  date      DateTime
  name      String
  year      Int
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model LeaveApplication {
  id            String       @id @default(cuid())
  employeeId    String
  employee      Employee     @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  leaveType     LeaveType
  fromDate      DateTime
  toDate        DateTime
  isHalfDay     Boolean      @default(false)
  halfDaySlot   HalfDaySlot?
  totalDays     Float
  reason        String
  attachmentUrl String?
  status          LeaveStatus  @default(PENDING)
  adminComment    String?
  isAdminEntry    Boolean      @default(false)
  isUnpaid        Boolean      @default(false)
  paidDays        Float?
  unpaidDays      Float?
  noticeViolation Boolean      @default(false)
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt

  @@index([employeeId, status])
  @@index([employeeId, fromDate])
  @@index([status, fromDate])
}

model WfhApplication {
  id           String       @id @default(cuid())
  employeeId   String
  employee     Employee     @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  date         DateTime
  toDate       DateTime?
  isHalfDay    Boolean      @default(false)
  halfDaySlot  HalfDaySlot?
  totalDays    Float        @default(1)
  reason       String
  status       WfhStatus    @default(PENDING)
  adminComment String?
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt

  @@index([employeeId, status])
  @@index([employeeId, date])
  @@index([status, date])
}

model LeaveBalance {
  id              String    @id @default(cuid())
  employeeId      String
  employee        Employee  @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  leaveType       LeaveType
  year            Int
  totalDays       Float
  usedDays        Float     @default(0)
  unpaidDaysUsed  Float     @default(0)
  remainingDays   Float
  isArchived      Boolean   @default(false)
  archivedAt      DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  // isArchived in the key allows one active + one archived per (employee, type, year)
  @@unique([employeeId, leaveType, year, isArchived])
}

model AbsentRecord {
  id           String   @id @default(cuid())
  employeeId   String
  employee     Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  date         DateTime
  reason       String?
  overrideById String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([employeeId, date])
}

model AuditLog {
  id         String   @id @default(cuid())
  adminId    String
  adminName  String?
  action     String
  targetType String
  targetId   String
  meta       String?
  ipAddress  String?
  createdAt  DateTime @default(now())

  @@index([createdAt])
  @@index([adminId])
  @@index([action])
  @@index([targetType])
}

model OrgSettings {
  id                       String   @id @default("global")
  orgName                  String   @default("Innovizia")
  timezone                 String   @default("Asia/Kolkata")
  monthlyLeaveLimitEnabled Boolean  @default(false)
  monthlyLeaveLimit        Float?

  // Check-in / Check-out settings
  checkInEnabled           Boolean  @default(false)
  checkInCodeTime          String   @default("09:00") // HH:MM when daily code is generated
  checkInStartTime         String   @default("07:00") // earliest allowed check-in
  checkInDeadline          String   @default("10:30") // after this = late
  checkInBufferMinutes     Int      @default(0)        // grace buffer: late marked only after deadline + buffer
  checkOutExpected         String   @default("18:00") // standard checkout time
  checkInWindowEnd         String   @default("13:00") // after this = can't check in
  weeklyEmailEnabled       Boolean  @default(false)   // send weekly attendance summary to employees

  // Attendance presence mode
  // AUTO_PRESENT: working days auto-show Present unless overridden
  // FROM_CHECKIN: Present only if a CheckInRecord exists; else NC (No Check-In)
  attendanceMode           String   @default("AUTO_PRESENT")

  updatedAt                DateTime @updatedAt
}

model Department {
  id        String   @id @default(cuid())
  name      String   @unique
  createdAt DateTime @default(now())
}

model EmployeeRole {
  id        String   @id @default(cuid())
  name      String   @unique
  createdAt DateTime @default(now())
}

model Notification {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  type      String
  message   String
  isRead    Boolean  @default(false)
  link      String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId, isRead])
  @@index([userId, createdAt])
}

model EmailTemplate {
  id          String   @id @default(cuid())
  key         String   @unique
  name        String
  description String
  category    String
  subject     String
  bodyHtml    String   @db.Text
  variables   Json
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model MonthlyReport {
  id               String   @id @default(cuid())
  employeeId       String
  employee         Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  month            Int      // 1–12
  year             Int
  totalWorkingDays Int
  presentDays      Float
  leaveDays        Float
  paidLeaveDays    Float    @default(0)
  unpaidLeaveDays  Float    @default(0)
  absentDays       Float
  wfhDays          Float
  attendancePct    Float
  generatedAt      DateTime @default(now())

  @@unique([employeeId, month, year])
}

model AttendanceCorrection {
  id              String   @id @default(cuid())
  employeeId      String
  employee        Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  date            DateTime
  correctedStatus String
  originalStatus  String
  reason          String?
  correctedBy     String   // admin userId
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@unique([employeeId, date])
  @@index([employeeId, date])
}

model DataBackup {
  id            String   @id @default(cuid())
  createdAt     DateTime @default(now())
  type          String   @default("DAILY")   // DAILY | MANUAL
  label         String?
  employeeCount Int      @default(0)
  policyCount   Int      @default(0)
  leaveCount    Int      @default(0)
  sizeBytes     Int?
  data          Json

  @@index([type, createdAt])
}

model PasswordResetToken {
  id        String   @id @default(cuid())
  email     String
  otp       String
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([email])
  @@index([expiresAt])
}

enum TicketStatus {
  OPEN
  RESOLVED
}

model SupportTicket {
  id        String       @id @default(cuid())
  name      String
  email     String
  mobile    String?
  reason    String
  status    TicketStatus @default(OPEN)
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt
}

enum AnnouncementPriority {
  HIGH
  MEDIUM
  LOW
}

model Announcement {
  id               String               @id @default(cuid())
  title            String
  content          String               @db.Text
  priority         AnnouncementPriority @default(MEDIUM)
  scheduledAt      DateTime?
  expiresAt        DateTime?
  isActive         Boolean              @default(true)
  isBirthday       Boolean              @default(false)
  targetEmployeeId String?
  createdAt        DateTime             @default(now())
  updatedAt        DateTime             @updatedAt
  dismissals       AnnouncementDismissal[]
}

model AnnouncementDismissal {
  id             String       @id @default(cuid())
  announcementId String
  announcement   Announcement @relation(fields: [announcementId], references: [id], onDelete: Cascade)
  employeeId     String
  employee       Employee     @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  dismissedAt    DateTime     @default(now())

  @@unique([announcementId, employeeId])
}

// ── Check-In / Check-Out Module ───────────────────────────────────────────────

enum CheckInStatus {
  NOT_CHECKED_IN
  CHECKED_IN
  CHECKED_OUT
  ABSENT
  ON_LEAVE
  ON_WFH
}

enum SwapDayStatus {
  PENDING_COMPENSATION
  COMPENSATED
  DEFAULTED
}

model DailyCheckInCode {
  id        String   @id @default(cuid())
  code      String
  date      String   // YYYY-MM-DD
  expiresAt DateTime
  createdBy String?  // admin userId (null = cron-generated)
  createdAt DateTime @default(now())

  @@unique([date])
  @@index([date])
}

model CheckInRecord {
  id              String        @id @default(cuid())
  employeeId      String
  employee        Employee      @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  date            String        // YYYY-MM-DD — one record per employee per day
  checkInTime     DateTime?
  checkOutTime    DateTime?

  // Location at check-in
  checkInLat      Float?
  checkInLng      Float?
  checkInAddress  String?

  // Location at check-out
  checkOutLat     Float?
  checkOutLng     Float?
  checkOutAddress String?

  checkInIp       String?
  checkOutIp      String?

  isLate          Boolean       @default(false)
  lateMinutes     Int?          // minutes past deadline
  earlyCheckout   Boolean       @default(false)
  earlyMinutes    Int?          // minutes before expected checkout
  workingHours    Float?        // calculated on checkout
  status          CheckInStatus @default(NOT_CHECKED_IN)
  adminOverride   Boolean       @default(false)
  adminNote       String?

  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  @@unique([employeeId, date])
  @@index([date])
  @@index([employeeId])
  @@index([status])
}

// ── Late Record ───────────────────────────────────────────────────────────────
// Single source of truth for late marks — both auto-detected (from CheckIn) and manual (admin).
// source: "AUTO" | "MANUAL"

model LateRecord {
  id          String   @id @default(cuid())
  employeeId  String
  employee    Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  date        DateTime // UTC midnight date only
  lateMinutes Int      @default(0)
  note        String?
  source      String   @default("MANUAL") // AUTO | MANUAL
  markedById  String?  // admin userId (null for AUTO)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([employeeId, date])
  @@index([employeeId])
  @@index([date])
}

// ── Swap Day Module ───────────────────────────────────────────────────────────

model SwapDay {
  id               String        @id @default(cuid())
  employeeId       String
  employee         Employee      @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  absentDate       DateTime      // the day the employee missed work
  compensationDate DateTime?     // the makeup day assigned by admin (can be set later)
  deadline         DateTime?     // set when compensationDate is assigned
  status           SwapDayStatus @default(PENDING_COMPENSATION)
  absentMarked     Boolean       @default(false) // true once AbsentRecord is created
  absentRecordId   String?       // FK ref after absent is marked
  note             String?
  createdById      String        // admin userId who created
  resolvedById     String?       // admin userId who marked compensated/defaulted
  resolvedAt       DateTime?
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt

  @@index([employeeId, status])
  @@index([status, deadline])
  @@index([compensationDate])
}
