# Copy to .env.local (dev) — production values are written by deploy/deploy.sh

# Backend API base URL. Dev: http://localhost:3001/api. Prod: https://<domain>/api
NEXT_PUBLIC_API_URL=http://localhost:3001/api

# Server-only (NO NEXT_PUBLIC_ prefix → never sent to the browser).
# Used by middleware.ts to cryptographically verify the auth JWT.
# MUST exactly match the backend's JWT_SECRET.
JWT_SECRET=must-match-backend-jwt-secret
